function openCoilPanel(sortBy) {
  _coilSort = sortBy || 'coilNo';
  _coilQuery = '';
  document.getElementById('coilPanelSearch').value = '';
  _buildCoilEntries();
  _renderCoilPanel();
  document.getElementById('coilPanelOverlay').style.display = 'flex';
}

function closeCoilPanel() {
  document.getElementById('coilPanelOverlay').style.display = 'none';
}

function coilPanelSetSort(s) {
  _coilSort = s;
  const idMap = { coilNo:'cpSortCoil', vendor:'cpSortVendor', date:'cpSortDate' };
  Object.keys(idMap).forEach(k => {
    document.getElementById(idMap[k]).classList.toggle('active', k === s);
  });
  _renderCoilPanel();
}

function coilPanelFilter() {
  _coilQuery = (document.getElementById('coilPanelSearch').value || '').toLowerCase();
  _renderCoilPanel();
}

function _renderCoilPanel() {
  // Filter
  let list = _coilEntries.filter(e => {
    if (!_coilQuery) return true;
    return (e.coilNo + ' ' + e.vendor + ' ' + e.mc + ' ' + e.raw).toLowerCase().includes(_coilQuery);
  });

  // Sort
  if (_coilSort === 'vendor') {
    list.sort((a, b) => (a.vendor||'').localeCompare(b.vendor||'') || (a.coilNo||'').localeCompare(b.coilNo||''));
  } else if (_coilSort === 'date') {
    list.sort((a, b) => (a.date||'').localeCompare(b.date||'') || (a.mc||'').localeCompare(b.mc||'') || a.slot - b.slot);
  } else {
    list.sort((a, b) => (a.coilNo||'').localeCompare(b.coilNo||'') || (a.vendor||'').localeCompare(b.vendor||''));
  }

  // Title
  const titles = { coilNo: '🔢 Coil No. — รายการทั้งหมด', vendor: '🏷 Vendor — รายการทั้งหมด', date: '📅 วันที่ / เครื่อง — รายการทั้งหมด' };
  document.getElementById('coilPanelTitle').textContent = titles[_coilSort] || titles.coilNo;
  document.getElementById('coilPanelCount').textContent = `(${list.length} coil entries)`;

  // Build rows with group separators
  const tbody = document.getElementById('coilPanelBody');
  let lastGroup = null;
  let rows = '';
  let rowNo = 0;

  list.forEach(e => {
    const group = _coilSort === 'vendor' ? e.vendor
                : _coilSort === 'date'   ? (e.date + ' — ' + e.mc)
                : e.coilNo.charAt(0).toUpperCase() || '#';

    if (group !== lastGroup) {
      const groupLabel = _coilSort === 'vendor' ? `🏷 ${esc(group)}`
                       : _coilSort === 'date'   ? `📅 ${esc(group)}`
                       : `🔢 ${esc(group)}`;
      rows += `<tr class="cp-sep"><td colspan="14">${groupLabel}</td></tr>`;
      lastGroup = group;
    }

    rowNo++;
    const bpColor = e.blackPoint >= 8 ? 'color:#ef9a9a' : (e.blackPoint >= 5 ? 'color:#ffe082' : 'color:#a5d6a7');
    const resBadge = e.result === 'NG'
      ? `<span class="cp-ng">NG</span>`
      : `<span class="cp-ok">OK</span>`;

    rows += `<tr>
      <td class="cp-no">${rowNo}</td>
      <td class="cp-raw">${esc(e.raw.substring(0, 22))}</td>
      <td class="cp-vendor">${esc(e.vendor)}</td>
      <td class="cp-coilno">${esc(e.coilNo)}</td>
      <td class="cp-bp" style="${bpColor}">${e.blackPoint}</td>
      <td>${resBadge}</td>
      <td class="cp-mc">${esc(e.mc)}</td>
      <td style="color:var(--dim);font-size:11px">${esc(e.date)}</td>
    </tr>`;
  });

  if (!rows) rows = `<tr><td colspan="14" style="text-align:center;color:var(--dim);padding:24px">ไม่พบข้อมูล</td></tr>`;
  tbody.innerHTML = rows;
}

