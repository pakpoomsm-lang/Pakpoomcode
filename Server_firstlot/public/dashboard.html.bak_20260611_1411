<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Dashboard — Expander First Lot Check</title>
<style>
/* ── Reset & Base ─────────────────────────────────────── */
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0d1117; --surface:#161b22; --surface2:#1f2937;
  --border:#30363d; --text:#e6edf3; --dim:#8b949e;
  --ok:#2ea043; --ok-bg:#0d2818; --ok-light:#a5d6a7;
  --ng:#da3633; --ng-bg:#2d0f0f; --ng-light:#ef9a9a;
  --warn:#d29922; --warn-bg:#271d00; --warn-light:#ffe082;
  --accent:#1f6feb; --accent2:#388bfd;
  --mono:'Consolas','Courier New',monospace;
}
body{background:var(--bg);color:var(--text);font-family:'Segoe UI',system-ui,sans-serif;font-size:14px;min-height:100vh}

/* ── Top Bar ──────────────────────────────────────────── */
#topbar{
  background:var(--surface);border-bottom:1px solid var(--border);
  padding:10px 20px;display:flex;align-items:center;gap:12px;
  position:sticky;top:0;z-index:100
}
#topbar h1{font-size:16px;font-weight:700;color:var(--text-dim);white-space:nowrap}
#topbar h1 span{color:var(--accent2)}
.tb-sep{flex:1}
#lastUpdate{font-size:12px;color:var(--dim)}
#refreshBtn{
  background:var(--accent);color:#fff;border:none;border-radius:6px;
  padding:6px 14px;font-size:13px;cursor:pointer;font-weight:600
}
#refreshBtn:hover{background:var(--accent2)}
#homeBtn{
  background:var(--surface2);color:var(--text);border:1px solid var(--border);
  border-radius:6px;padding:6px 14px;font-size:13px;cursor:pointer;
  text-decoration:none;display:inline-flex;align-items:center;gap:5px
}
#homeBtn:hover{background:var(--border)}
.auto-badge{
  background:var(--ok-bg);color:var(--ok-light);border:1px solid var(--ok);
  border-radius:10px;font-size:11px;padding:2px 8px;
}

/* ── Layout ───────────────────────────────────────────── */
.page{padding:16px 20px;max-width:1400px;margin:0 auto}
.section-title{font-size:13px;font-weight:700;color:var(--dim);
  text-transform:uppercase;letter-spacing:.8px;margin:18px 0 10px}

/* ── Summary Row ──────────────────────────────────────── */
#summaryRow{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:6px}
.sum-card{
  background:var(--surface);border:1px solid var(--border);border-radius:10px;
  padding:14px 20px;min-width:130px;flex:1
}
.sum-card .val{font-size:28px;font-weight:800;line-height:1.1}
.sum-card .lbl{font-size:11px;color:var(--dim);margin-top:2px}
.sum-total .val{color:var(--accent2)}
.sum-pass  .val{color:var(--ok-light)}
.sum-fail  .val{color:var(--ng-light)}
.sum-today .val{color:var(--warn-light)}

/* ── Machine Cards ────────────────────────────────────── */
#machineGrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px}
.m-card{
  background:var(--surface);border:1px solid var(--border);border-radius:12px;
  padding:14px 16px;position:relative;overflow:hidden;
  transition:border-color .2s
}
.m-card.pass{border-color:var(--ok)}
.m-card.fail{border-color:var(--ng)}
.m-card .mc-machine{font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px}
.m-card .mc-status{
  display:inline-block;padding:3px 10px;border-radius:5px;font-size:12px;font-weight:700;
  margin-bottom:8px
}
.mc-status.pass{background:var(--ok-bg);color:var(--ok-light);border:1px solid var(--ok)}
.mc-status.fail{background:var(--ng-bg);color:var(--ng-light);border:1px solid var(--ng)}
.mc-status.na  {background:var(--surface2);color:var(--dim);border:1px solid var(--border)}
.m-card .mc-fg{font-size:13px;font-family:var(--mono);color:var(--accent2);margin-bottom:4px;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.m-card .mc-row{font-size:12px;color:var(--dim);margin:2px 0}
.m-card .mc-row span{color:var(--text)}
.m-card .mc-time{font-size:11px;color:var(--dim);margin-top:8px;border-top:1px solid var(--border);padding-top:6px}
.m-card .mc-count{
  position:absolute;top:14px;right:14px;
  background:var(--surface2);border:1px solid var(--border);
  border-radius:8px;padding:3px 9px;font-size:11px;color:var(--dim);text-align:center
}
.m-card .mc-count .n{font-size:16px;font-weight:700;color:var(--warn-light);display:block}
.no-machine{color:var(--dim);font-size:13px;padding:20px 0}

/* ── Log Table ────────────────────────────────────────── */
#filterRow{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;align-items:center}
/* Date range label */
.flt-date-sep{font-size:12px;color:var(--dim);white-space:nowrap;display:flex;align-items:center;padding:0 2px}
input[type="date"].flt{width:135px;cursor:pointer}
input[type="date"].flt::-webkit-calendar-picker-indicator{filter:invert(.6)}

.flt{
  background:var(--surface);border:1px solid var(--border);color:var(--text);
  border-radius:6px;padding:6px 10px;font-size:13px;outline:none
}
.flt:focus{border-color:var(--accent)}
#searchBox{min-width:200px}
.flt-btn{
  background:var(--surface2);color:var(--text);border:1px solid var(--border);
  border-radius:6px;padding:6px 14px;font-size:13px;cursor:pointer
}
.flt-btn:hover{background:var(--border)}
.exp-btn{
  background:var(--ok);color:#fff;border:none;border-radius:6px;
  padding:6px 14px;font-size:13px;cursor:pointer;font-weight:600
}
.exp-btn:hover{background:var(--ok-light);color:#000}
.exp-csv-btn{
  background:var(--warn);color:#000;border:none;border-radius:6px;
  padding:6px 14px;font-size:13px;cursor:pointer;font-weight:600
}
.exp-csv-btn:hover{opacity:.85}
#recordCount{font-size:12px;color:var(--dim);margin-left:4px}

.tbl-wrap{overflow-x:auto;border:1px solid var(--border);border-radius:10px}
table{width:100%;border-collapse:collapse;font-size:12px}
thead th{
  background:var(--surface2);color:var(--dim);padding:8px 10px;
  text-align:left;font-weight:600;white-space:nowrap;
  border-bottom:1px solid var(--border);position:sticky;top:0
}
tbody tr{border-bottom:1px solid var(--border)}
tbody tr:hover{background:var(--surface2)}
tbody td{padding:7px 10px;white-space:nowrap;max-width:200px;overflow:hidden;text-overflow:ellipsis}
.badge-pass{background:var(--ok-bg);color:var(--ok-light);border:1px solid var(--ok);
  border-radius:4px;padding:1px 7px;font-size:11px;font-weight:700}
.badge-fail{background:var(--ng-bg);color:var(--ng-light);border:1px solid var(--ng);
  border-radius:4px;padding:1px 7px;font-size:11px;font-weight:700}
.badge-na{background:var(--surface2);color:var(--dim);border:1px solid var(--border);
  border-radius:4px;padding:1px 7px;font-size:11px}
.td-id{color:var(--dim);width:40px}
.td-fg{font-family:var(--mono);color:var(--accent2)}
.td-machine{font-weight:600}

/* HP Machine Grid — same as Expander grid */
#hpMachineGrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px}

/* ── Cutting Machine Grid — 1:1 square cards ───────── */
#cutMachineGrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:12px}
.cut-mc-card{
  background:var(--surface);border:2px solid var(--border);border-radius:14px;
  aspect-ratio:1/1;display:flex;flex-direction:column;
  padding:12px 12px 10px;position:relative;overflow:hidden;
  transition:border-color .2s,box-shadow .2s
}
.cut-mc-card.pass{border-color:var(--ok);box-shadow:0 0 0 1px var(--ok-bg) inset}
.cut-mc-card.fail{border-color:var(--ng);box-shadow:0 0 0 1px var(--ng-bg) inset}
.cut-mc-card .cmc-header{display:flex;align-items:flex-start;justify-content:space-between;gap:4px;min-height:0}
.cut-mc-card .cmc-name{
  font-size:12px;font-weight:800;color:var(--text);line-height:1.3;
  word-break:break-word;flex:1;overflow:hidden
}
.cut-mc-card .cmc-cnt{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:20px;font-size:11px;font-weight:800;color:var(--warn-light);
  padding:1px 8px;white-space:nowrap;flex-shrink:0;line-height:1.6
}
.cut-mc-card .cmc-mid{
  flex:1;display:flex;align-items:center;justify-content:center;padding:6px 0
}
.cmc-stat{
  font-size:22px;font-weight:900;padding:8px 22px;border-radius:10px;
  letter-spacing:2px;text-align:center;line-height:1
}
.cmc-stat.pass{background:var(--ok-bg);color:var(--ok-light);border:2px solid var(--ok)}
.cmc-stat.fail{background:var(--ng-bg);color:var(--ng-light);border:2px solid var(--ng)}
.cut-mc-card .cmc-detail{
  display:flex;flex-direction:column;gap:2px;min-height:0
}
.cut-mc-card .cmc-fg{
  font-family:var(--mono);font-size:10px;color:var(--accent2);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis
}
.cut-mc-card .cmc-row{font-size:10px;color:var(--dim);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cut-mc-card .cmc-row span{color:var(--text);font-weight:600}
.cut-mc-card .cmc-time{
  font-size:10px;color:var(--dim);margin-top:3px;
  border-top:1px solid var(--border);padding-top:4px
}

/* FP Detail Modal */
#fpDetailOverlay{
  position:fixed;inset:0;z-index:300;
  background:rgba(0,0,0,.75);
  display:flex;align-items:flex-start;justify-content:center;
  padding:32px 16px 20px;overflow-y:auto
}
#fpDetailPanel{
  background:var(--surface);border:1px solid #b45309;border-radius:14px;
  width:100%;max-width:860px;overflow:hidden;
  box-shadow:0 8px 40px rgba(0,0,0,.7)
}
.fp-det-hdr{
  background:#3d1c00;border-bottom:1px solid #b45309;
  padding:12px 18px;display:flex;align-items:center;gap:10px
}
.fp-det-title{font-size:15px;font-weight:800;color:#fdba74;flex:1}
.fp-det-close{
  background:#7c2d12;color:#fed7aa;border:1px solid #b45309;border-radius:6px;
  padding:5px 14px;font-size:13px;cursor:pointer;font-weight:700
}
.fp-det-close:hover{background:#b45309}
.fp-det-body{padding:14px 18px;display:flex;flex-direction:column;gap:10px}
.fp-det-section{
  border:1px solid var(--border);border-radius:8px;overflow:hidden
}
.fp-det-sec-hdr{
  background:var(--surface2);padding:6px 12px;
  font-size:11px;font-weight:700;color:var(--dim);
  text-transform:uppercase;letter-spacing:.7px;border-bottom:1px solid var(--border)
}
.fp-det-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:0
}
.fp-det-grid.g2{grid-template-columns:repeat(2,1fr)}
.fp-det-grid.g3{grid-template-columns:repeat(3,1fr)}
.fp-det-grid.g5{grid-template-columns:repeat(5,1fr)}
.fp-det-cell{
  padding:7px 10px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);
  display:flex;flex-direction:column;gap:2px
}
.fp-det-cell:last-child,.fp-det-cell:nth-child(4n){border-right:none}
.fp-det-lbl{font-size:10px;color:var(--dim);font-weight:600;letter-spacing:.4px}
.fp-det-val{font-size:14px;font-weight:700;color:var(--text);font-family:var(--mono)}
.fp-det-val.ok{color:#4ade80}
.fp-det-val.ng{color:#f87171}
.fp-det-val.avg{font-size:16px;color:#fbbf24}
.fp-det-avg-row{
  display:grid;grid-template-columns:1fr auto auto;
  background:rgba(251,191,36,.07);padding:7px 12px;
  align-items:center;gap:10px;border-top:1px solid var(--border)
}
.fp-det-avg-lbl{font-size:12px;color:#fbbf24;font-weight:700}
.fp-det-avg-val{font-size:18px;font-weight:800;color:#fbbf24;font-family:var(--mono)}
.fp-det-result-badge{padding:3px 14px;border-radius:5px;font-size:13px;font-weight:800}
.detail-btn{
  background:#7c3a04;color:#fdba74;border:1px solid #b45309;
  border-radius:4px;padding:2px 8px;font-size:11px;cursor:pointer;
  white-space:nowrap;font-weight:700
}
.detail-btn:hover{background:#b45309}

/* Coil Panel Modal */
#coilPanelOverlay{
  position:fixed;inset:0;z-index:300;
  background:rgba(0,0,0,.72);
  display:flex;align-items:flex-start;justify-content:center;
  padding:40px 20px 20px;overflow-y:auto
}
#coilPanel{
  background:var(--surface);border:1px solid #2e7d32;border-radius:14px;
  width:100%;max-width:1100px;padding:0;overflow:hidden;
  box-shadow:0 8px 40px rgba(0,0,0,.7)
}
#coilPanelHeader{
  background:#0d2818;border-bottom:1px solid #2e7d32;
  padding:14px 20px;display:flex;align-items:center;gap:10px
}
#coilPanelTitle{
  font-size:15px;font-weight:800;color:#a5d6a7;flex:1
}
#coilPanelClose{
  background:#1b5e20;color:#a5d6a7;border:1px solid #2e7d32;border-radius:6px;
  padding:5px 14px;font-size:13px;cursor:pointer;font-weight:700
}
#coilPanelClose:hover{background:#2e7d32}
#coilPanelToolbar{
  padding:10px 16px;display:flex;gap:8px;align-items:center;
  border-bottom:1px solid var(--border);background:var(--surface2)
}
.cpanel-sort-btn{
  background:var(--surface);color:var(--dim);border:1px solid var(--border);
  border-radius:6px;padding:5px 14px;font-size:12px;cursor:pointer;font-weight:600
}
.cpanel-sort-btn.active{background:#1b5e20;color:#a5d6a7;border-color:#2e7d32}
.cpanel-sort-btn:hover:not(.active){background:var(--border);color:var(--text)}
#coilPanelCount{font-size:12px;color:var(--dim);margin-left:4px}
#coilPanelWrap{overflow-x:auto;max-height:65vh}
#coilPanelTable{width:100%;border-collapse:collapse;font-size:12px}
#coilPanelTable thead th{
  background:#0a1f0a;color:#66bb6a;padding:8px 10px;
  text-align:left;font-weight:700;white-space:nowrap;
  border-bottom:1px solid #2e7d32;position:sticky;top:0;z-index:1
}
#coilPanelTable tbody tr{border-bottom:1px solid #1b2e1b}
#coilPanelTable tbody tr:hover{background:#0d2818}
#coilPanelTable tbody td{padding:6px 10px;white-space:nowrap}
.cp-no{color:var(--dim);width:36px;text-align:center;font-weight:700}
.cp-coilno{font-family:var(--mono);color:#80deea;font-weight:700}
.cp-vendor{color:#a5d6a7;font-weight:700}
.cp-raw{font-size:10px;color:var(--dim);max-width:160px;overflow:hidden;text-overflow:ellipsis}
.cp-bp{color:#ffe082;font-weight:700;text-align:center}
.cp-ok{color:#a5d6a7;font-weight:700;background:#0d2818;border-radius:4px;padding:1px 8px}
.cp-ng{color:#ef9a9a;font-weight:700;background:#2d0f0f;border-radius:4px;padding:1px 8px}
.cp-mc{color:#bb86fc;font-weight:600}
.cp-sep{background:#0a1f0a!important}
.cp-sep td{color:#66bb6a;font-weight:700;font-size:11px;padding:4px 10px!important;border-bottom:1px solid #2e7d32!important}

/* Pagination */
#pagRow{display:flex;align-items:center;gap:8px;margin-top:10px;justify-content:flex-end}
.pg-btn{
  background:var(--surface);border:1px solid var(--border);color:var(--text);
  border-radius:5px;padding:4px 10px;cursor:pointer;font-size:12px
}
.pg-btn:disabled{opacity:.3;cursor:default}
.pg-btn:hover:not(:disabled){background:var(--border)}
#pgInfo{font-size:12px;color:var(--dim)}

/* ── Process Tabs ─────────────────────────────────────── */
#processTabs{
  display:flex;gap:6px;padding:14px 20px 0;
  border-bottom:2px solid var(--border);
  background:var(--surface);
  position:sticky;top:57px;z-index:90
}
.proc-tab{
  padding:8px 22px;border:1px solid var(--border);border-bottom:none;
  border-radius:8px 8px 0 0;background:var(--surface2);color:var(--dim);
  font-size:13px;font-weight:700;cursor:pointer;transition:all .15s;
  white-space:nowrap
}
.proc-tab:hover{background:var(--border);color:var(--text)}
.proc-tab.active-exp{background:var(--accent);color:#fff;border-color:var(--accent)}
.proc-tab.active-cut{background:#1565c0;color:#fff;border-color:#1565c0}
.proc-tab.active-hp{background:#2e7d32;color:#fff;border-color:#2e7d32}
.proc-tab.active-fp{background:#b45309;color:#fff;border-color:#b45309}

/* ── Process Select Screen ────────────────────────────── */
#processSelect{
  position:fixed;inset:0;z-index:200;
  background:var(--bg);
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:32px
}
#processSelect h2{
  font-size:22px;font-weight:800;color:var(--text);letter-spacing:1px;
  text-align:center
}
#processSelect h2 span{color:var(--accent2)}
.ps-grid{display:flex;gap:24px;flex-wrap:wrap;justify-content:center}
.ps-card{
  background:var(--surface);border:2px solid var(--border);border-radius:16px;
  padding:36px 44px;cursor:pointer;text-align:center;min-width:200px;
  transition:all .2s;display:flex;flex-direction:column;align-items:center;gap:14px
}
.ps-card:hover{transform:translateY(-4px);box-shadow:0 8px 32px rgba(0,0,0,.5)}
.ps-card .ps-icon{font-size:52px;line-height:1}
.ps-card .ps-name{font-size:15px;font-weight:700;color:var(--text)}
.ps-card .ps-sub{font-size:11px;color:var(--dim);margin-top:2px}
.ps-card.ps-exp{border-color:var(--accent)}
.ps-card.ps-exp:hover{background:#0d1b3e;border-color:var(--accent2)}
.ps-card.ps-hp{border-color:#4caf50}
.ps-card.ps-hp:hover{background:#0a1f0a;border-color:#81c784}
.ps-card.ps-cut{border-color:#64b5f6}
.ps-card.ps-cut:hover{background:#0a1628;border-color:#90caf9}
.ps-card.ps-fp{border-color:#f97316}
.ps-card.ps-fp:hover{background:#1c0b00;border-color:#fb923c}
/* Program launch buttons */
.prog-row{display:flex;gap:16px;flex-wrap:wrap;justify-content:center;margin-top:20px;padding-top:18px;border-top:1px solid var(--border)}
.prog-row-label{width:100%;text-align:center;font-size:11px;color:var(--dim);font-weight:600;letter-spacing:.8px;text-transform:uppercase;margin-bottom:2px}
.prog-btn{
  display:flex;align-items:center;gap:8px;
  padding:10px 22px;border-radius:8px;border:2px solid;
  font-size:13px;font-weight:700;cursor:pointer;text-decoration:none;
  transition:all .15s;background:var(--surface2)
}
.prog-btn:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.5)}
.prog-btn.pb-hp  {color:#a5d6a7;border-color:#4caf50}.prog-btn.pb-hp:hover{background:#0a1f0a}
.prog-btn.pb-fp  {color:#fdba74;border-color:#f97316}.prog-btn.pb-fp:hover{background:#1c0b00}
.prog-btn.pb-exp {color:#90caf9;border-color:#1f6feb}.prog-btn.pb-exp:hover{background:#0d1b3e}
.prog-btn.pb-cut {color:#90caf9;border-color:#64b5f6}.prog-btn.pb-cut:hover{background:#0a1628}

/* ── Admin PIN Modal ─────────────────────────────────── */
#adminPinOverlay{
  display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);
  z-index:2000;align-items:center;justify-content:center
}
#adminPinOverlay.open{display:flex}
#adminPinBox{
  background:#161b22;border:1px solid #30363d;border-radius:14px;
  padding:32px 36px;text-align:center;min-width:300px;
  box-shadow:0 16px 48px rgba(0,0,0,.6)
}
#adminPinBox h3{font-size:16px;font-weight:700;color:#e6edf3;margin-bottom:6px}
#adminPinBox p{font-size:12px;color:#8b949e;margin-bottom:20px}
#adminPinInput{
  background:#0d1117;border:1px solid #30363d;color:#e6edf3;
  border-radius:8px;padding:10px 16px;font-size:22px;letter-spacing:10px;
  width:160px;text-align:center;outline:none;display:block;margin:0 auto 14px
}
#adminPinInput:focus{border-color:#1f6feb}
#adminPinErr{color:#f85149;font-size:12px;min-height:18px;margin-bottom:10px}
.admin-pin-btns{display:flex;gap:8px;justify-content:center}
.admin-pin-ok{
  background:#1f6feb;color:#fff;border:none;border-radius:7px;
  padding:8px 22px;font-size:14px;cursor:pointer;font-weight:700
}
.admin-pin-ok:hover{background:#388bfd}
.admin-pin-cancel{
  background:#21262d;color:#8b949e;border:1px solid #30363d;border-radius:7px;
  padding:8px 16px;font-size:14px;cursor:pointer
}
.admin-pin-cancel:hover{background:#30363d}

/* ── Toast ────────────────────────────────────────────── */
#toast{
  position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(60px);
  background:#323232;color:#fff;padding:10px 22px;border-radius:8px;
  font-size:13px;opacity:0;transition:all .3s;z-index:999;pointer-events:none
}
