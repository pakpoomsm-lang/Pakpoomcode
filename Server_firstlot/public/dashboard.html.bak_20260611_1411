  const r = fpFiltered[idx];
  if (!r) return;

  document.getElementById('fpDetTitle').innerHTML =
    `📋 FP Detail &nbsp;·&nbsp; <span style="color:#fdba74">${esc(r.mc||'—')}</span>`+
    ` &nbsp;|&nbsp; <span style="color:#93c5fd;font-family:var(--mono)">${esc(r.item||'—')}</span>`+
    ` &nbsp;|&nbsp; ${esc(r.date||'')} ${esc(r.time||'')}`;

  const fmt  = v => (v !== '' && v != null) ? String(v) : '—';
  const res  = (v,good='OK') => {
    if (!v || v==='' || v==='—') return '<span class="badge-na">—</span>';
    return v.toUpperCase().includes(good)
      ? '<span class="badge-pass">OK</span>'
      : '<span class="badge-fail">NG</span>';
  };
  const cell = (lbl, val, cls='') =>
    `<div class="fp-det-cell"><span class="fp-det-lbl">${lbl}</span><span class="fp-det-val ${cls}">${esc(fmt(val))}</span></div>`;

  const measBlock = (label, p1, p2, p3, p4, avg, result, extra='') => `
    <div class="fp-det-section">
      <div class="fp-det-sec-hdr">${label}</div>
      <div class="fp-det-grid">
        ${cell('Point 1', p1)} ${cell('Point 2', p2)}
        ${cell('Point 3', p3)} ${cell('Point 4', p4)}
      </div>
      <div class="fp-det-avg-row">
        <span class="fp-det-avg-lbl">Average${extra}</span>
        <span class="fp-det-avg-val">${esc(fmt(avg))}</span>
        ${res(result)}
      </div>
    </div>`;

  const html = `
    <!-- Info Row -->
    <div class="fp-det-section">
      <div class="fp-det-sec-hdr">ข้อมูลทั่วไป</div>
      <div class="fp-det-grid g5">
        ${cell('วันที่', r.date)} ${cell('เวลา', r.time)}
        ${cell('เครื่อง', r.mc)} ${cell('Type', r.type)}
        ${cell('Lot', r.lot)}
        ${cell('Line', r.line)} ${cell('Seq', r.seq)}
        ${cell('Vendor', r.vendor)} ${cell('Mat Type', r.mat_type)}
        ${cell('Oil Type', r.oil)}
      </div>
    </div>

    <!-- FIN Pitch -->
    ${measBlock('🔵 FIN Pitch (mm)', r.fp1, r.fp2, r.fp3, r.fp4, r.fp_avg, r.result_fp,
      r.spec_pitch ? ` &nbsp;<span style="font-size:11px;color:var(--dim)">Spec: ${esc(r.spec_pitch)}</span>` : '')}

    <!-- FIN Flare -->
    ${measBlock('🟢 FIN Flare (mm)', r.ff1, r.ff2, r.ff3, r.ff4, r.ff_avg, r.result_ff)}

    <!-- SC (Scan 13) -->
    ${measBlock('🟡 SC Measurement', r.sc1, r.sc2, r.sc3, r.sc4, r.sc_avg, r.result_sc)}

    <!-- Appearance + Qty -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
      <div class="fp-det-section">
        <div class="fp-det-sec-hdr">Appearance Check</div>
        <div class="fp-det-grid g3">
          ${cell('Coil', r.appear_coil)} ${cell('SC Appear', r.sc_appear)}
          ${cell('Appear Result', '')}
        </div>
        <div class="fp-det-avg-row">
          <span class="fp-det-avg-lbl">Appear Result</span>
          <span></span>
          ${res(r.result_appear)}
        </div>
      </div>
      <div class="fp-det-section">
        <div class="fp-det-sec-hdr">Q\'ty Fin &amp; Final</div>
        <div class="fp-det-grid g2">
          ${cell("Q'ty Fin", r.qty_fin)} ${cell("Q'ty Result", '')}
          ${cell('Checker', r.checker)} ${cell('Confirmer', r.confirmer)}
        </div>
        <div class="fp-det-avg-row">
          <span class="fp-det-avg-lbl">Q'ty Result</span>
          <span></span>
          ${res(r.result_qty)}
        </div>
        <div style="padding:8px 12px;display:flex;align-items:center;gap:10px;border-top:1px solid var(--border)">
          <span style="font-size:12px;font-weight:700;color:var(--dim)">FINAL</span>
          ${r.final==='OK'
            ? '<span class="badge-pass" style="font-size:15px;padding:4px 18px">OK</span>'
            : (r.final==='NG'
              ? '<span class="badge-fail" style="font-size:15px;padding:4px 18px">NG</span>'
              : '<span class="badge-na" style="font-size:15px;padding:4px 18px">—</span>')}
        </div>
      </div>
    </div>`;

  document.getElementById('fpDetBody').innerHTML = html;
  document.getElementById('fpDetailOverlay').style.display = 'flex';
}

function closeFpDetail() {
  document.getElementById('fpDetailOverlay').style.display = 'none';
}

function fpExportCSV() {
  if (!fpFiltered.length) { showToast('ไม่มีข้อมูลให้ Export'); return; }
  const h = ['No','Date','Time','MC','Item FG','Type','Lot','Line','Seq',
             'Vendor','Mat Type','Oil Type','Appear','FP Avg',
             'FF Avg',"Q'ty","Q'ty Result",
             'Checker','Confirmer','Final'];
  const rows = fpFiltered.map((r,i) => [
    i+1, r.date, r.time, r.mc, r.item, r.type, r.lot, r.line, r.seq,
    r.vendor, r.mat_type, r.oil, r.result_appear,
    r.fp_avg, r.ff_avg,
    r.qty_fin, r.result_qty, r.checker, r.confirmer, r.final
  ].map(v => '"'+(String(v??'').replace(/"/g,'""'))+'"'));
  const csv = '﻿' + [h, ...rows].map(r=>r.join(',')).join('\r\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
  a.download = 'fp_firstlot_' + _localDateStr() + '.csv';
  a.click();
}

