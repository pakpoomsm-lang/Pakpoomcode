async function loadFP() {
  initDateFilters();
  try {
    const res = await fetch('/fp/api/records?limit=9999&page=1');
    const data = await res.json();
    // store flat record list
    fpAllRecords = (data.records || []);
    fpLoaded = true;
    // populate machine dropdown
    const _fpMCSel = document.getElementById('fpFltMC');
    if (_fpMCSel) {
      const _fpMCs = [...new Set(fpAllRecords.map(r => r.mc).filter(Boolean))].sort();
      const _fpCur = _fpMCSel.value;
      _fpMCSel.innerHTML = '<option value="">เครื่องทั้งหมด</option>' +
        _fpMCs.map(m => `<option value="${esc(m)}"${m===_fpCur?' selected':''}>${esc(m)}</option>`).join('');
    }
    // update KPIs from server summary
    document.getElementById('fpTotal').textContent    = data.total_all ?? '—';
    document.getElementById('fpOK').textContent       = data.ok_all    ?? '—';
    document.getElementById('fpNG').textContent       = data.ng_all    ?? '—';
    document.getElementById('fpToday').textContent    = data.today     ?? '—';
    document.getElementById('fpMachines').textContent = data.mc_active ?? '—';
    // คำนวณ mc_status จาก fpAllRecords (records เรียง DESC → ตัวแรกคือล่าสุด)
    // ใช้แบบนี้เพื่อให้ได้ครบทุก field: line, seq, type, checker, saved_at
    const _mcMap = {};
    fpAllRecords.forEach(r => {
      if (r.mc && !_mcMap[r.mc]) _mcMap[r.mc] = r;
    });
    fpUpdateMachineCards(Object.values(_mcMap));
    fpFilterLog();
    document.getElementById('lastUpdate').textContent =
      'อัปเดต: ' + new Date().toLocaleTimeString('th-TH');
  } catch(e) { showToast('❌ โหลดข้อมูล FP ไม่ได้: ' + e.message); }
}

function fpUpdateMachineCards(mcStatus) {
  const grid = document.getElementById('fpMachineGrid');

  // ── กรองเฉพาะ record ที่อยู่ใน Shift ปัจจุบัน ──────────────
  const shiftStart = getShiftStart();
  const inShift = mcStatus.filter(r => {
    // ใช้ saved_at ก่อน ถ้าไม่มีให้ใช้ date+time
    const dtStr = r.saved_at || (r.date && r.time ? r.date + 'T' + r.time : null);
    if (!dtStr) return false;
    return new Date(dtStr) >= shiftStart;
  });

  if (!inShift.length) {
    grid.innerHTML = '<div class="no-machine">ยังไม่มีข้อมูล Shift นี้</div>'; return;
  }
  grid.innerHTML = inShift.map(r => {
    const isOK = (r.final||'') === 'OK';
    const isNG = (r.final||'') === 'NG';
    const cls  = isOK ? 'pass' : (isNG ? 'fail' : '');
    const badge = isOK
      ? '<span class="mc-status pass">✓ OK</span>'
      : (isNG ? '<span class="mc-status fail">✗ NG</span>'
              : '<span class="mc-status na">— —</span>');
    return `<div class="m-card ${cls}">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
        <div class="mc-machine">🔧 ${esc(r.mc||'—')}</div>
        ${badge}
      </div>
      <div class="mc-fg">${esc(r.item||'—')}</div>
      <div class="mc-row">Type: <span>${esc(r.type||'—')}</span></div>
      <div class="mc-row">Line: <span>${esc(r.line||'—')}</span> &nbsp;|&nbsp; Seq: <span>${esc(r.seq||'—')}</span></div>
      <div class="mc-row">Checker: <span>${esc(r.checker||'—')}</span></div>
      <div class="mc-time">📅 ${esc(r.date||'—')} &nbsp;🕐 ${esc(r.time||'—')}</div>
    </div>`;
  }).join('');
}

function fpFilterLog() {
  const q    = (document.getElementById('fpSearchBox').value || '').toLowerCase();
  const mc   = document.getElementById('fpFltMC').value;
  const from = document.getElementById('fpFltDateFrom').value;
  const to_  = document.getElementById('fpFltDateTo').value;

  fpFiltered = fpAllRecords.filter(r => {
    if (mc && r.mc !== mc) return false;
    const rd = (r.date || '');
    if (from && rd < from) return false;
    if (to_  && rd > to_)  return false;
    if (q) {
      const hay = [r.mc,r.item,r.lot,r.checker,r.confirmer,r.type,r.final]
        .join(' ').toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });
  fpCurrentPage = 1;
  fpRenderTable();
}

function fpClearFilter() {
  const today = _localDateStr();
  document.getElementById('fpSearchBox').value   = '';
  document.getElementById('fpFltMC').value       = '';
  document.getElementById('fpFltDateFrom').value = today;
  document.getElementById('fpFltDateTo').value   = today;
  fpFilterLog();
}

