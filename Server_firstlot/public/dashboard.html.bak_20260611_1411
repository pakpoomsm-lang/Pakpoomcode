  fpRenderTable();
}

function fpChangePage(d) { fpCurrentPage += d; fpRenderTable(); }

function fpRenderTable() {
  const total = fpFiltered.length;
  const pages = Math.max(1, Math.ceil(total / fpPageSize));
  fpCurrentPage = Math.min(fpCurrentPage, pages);
  const start = (fpCurrentPage-1)*fpPageSize;
