let cutRecords = [], cutFiltered = [], cutPage = 1, cutPageSize = 10;

function cutInShift(r) {
  if (!r.saved_at) return false;
  return new Date(r.saved_at) >= getShiftStart();
}

async function loadCutting() {
  try {
    const res = await fetch('/cutting/api/cutting-records');
    cutRecords = await res.json();
    cutUpdateSummary();
    cutUpdateMachineCards();
    cutPopulateMachineFilter();
    cutFilterLog();
