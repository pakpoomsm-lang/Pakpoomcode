}

function cutUpdateSummary() {
  const today = _localDateStr();
  const shift = getCurrentShift();
  document.getElementById('cShiftLbl').textContent = shift === 'day' ? 'Day Shift นี้' : 'Night Shift นี้';
  document.getElementById('cTotal').textContent = cutRecords.length;
  document.getElementById('cOk').textContent    = cutRecords.filter(r=>r.status==='OK').length;
  document.getElementById('cNg').textContent    = cutRecords.filter(r=>r.status==='NG').length;
  document.getElementById('cShift').textContent = cutRecords.filter(cutInShift).length;
  document.getElementById('cToday').textContent = cutRecords.filter(r=>(r.saved_at||'').startsWith(today)).length;
