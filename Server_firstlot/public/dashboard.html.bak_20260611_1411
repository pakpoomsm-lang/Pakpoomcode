      <td>${esc(r.date||'')}</td>
      <td>${esc(r.time||'')}</td>
      <td class="td-machine">${esc(r.mc||'')}</td>
      <td class="td-fg">${esc(r.item||'')}</td>
      <td>${esc(r.type||'')}</td>
      <td>${esc(r.lot||'')}</td>
      <td>${esc(r.line||'')}</td>
      <td>${esc(r.seq||'')}</td>
      <td>${esc(r.vendor||'')}</td>
      <td>${esc(r.mat_type||'')}</td>
      <td>${esc(r.oil||'')}</td>
      <td>${apBadge}</td>
      <td style="font-weight:700">${esc(r.fp_avg||'—')}</td>
      <td style="font-weight:700">${esc(r.ff_avg||'—')}</td>
      <td>${esc(r.qty_fin||'')}</td>
      <td>${r.result_qty ? (r.result_qty.toUpperCase().includes('OK') ? '<span class="badge-pass">OK</span>' : '<span class="badge-fail">NG</span>') : '<span class="badge-na">—</span>'}</td>
      <td>${esc(r.checker||'')}</td>
      <td>${esc(r.confirmer||'')}</td>
      <td>${badge}</td>
      <td style="text-align:center"><button class="detail-btn" onclick="openFpDetail(${start+i})">🔍 Detail</button></td>
    </tr>`;
  }).join('');
