function cutUpdateMachineCards() {
  const shiftRecs = cutRecords.filter(cutInShift);
  const byLine = {};
  shiftRecs.forEach(r => {
    const key = r.mc_line || '—';
    if (!byLine[key]) byLine[key] = { count: 0 };
    byLine[key].count++;
    if (!byLine[key].last || r.id > byLine[key].last.id) byLine[key].last = r;
  });
  const grid = document.getElementById('cutMachineGrid');
  const lines = Object.keys(byLine).sort();
  if (!lines.length) { grid.innerHTML = '<div class="no-machine">ยังไม่มีข้อมูล Shift นี้</div>'; return; }
  grid.innerHTML = lines.map(m => {
    const d = byLine[m]; const r = d.last;
    const isOk = r.status === 'OK';
    const cls  = isOk ? 'pass' : 'fail';
    const dt   = r.saved_at ? new Date(r.saved_at).toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit',hour12:false}) : '—';
    return `<div class="cut-mc-card ${cls}">
      <div class="cmc-header">
        <div class="cmc-name">✂ ${esc(m)}</div>
        <div class="cmc-cnt">${d.count} <span style="font-size:9px;font-weight:400;color:var(--dim)">Shift</span></div>
