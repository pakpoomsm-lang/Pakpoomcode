async function fpExportExcel() {
  if (!fpFiltered.length) { showToast('ไม่มีข้อมูลให้ Export'); return; }
  showToast('⏳ กำลังสร้าง Excel...', '#555');
  try {
    // ส่ง id list ของ records ที่กรองแล้วไปยัง server
    const ids = fpFiltered.map(r => r.no);
    const res = await fetch('/fp/api/export-excel', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids: fpFiltered.map(r => r) })
    });
    if (!res.ok) throw new Error('Server error ' + res.status);
    const blob = await res.blob();
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = 'fp_firstlot_' + _localDateStr() + '.xlsx';
    a.click();
    URL.revokeObjectURL(url);
    showToast('✓ Export Excel สำเร็จ', '#006600');
  } catch(e) { showToast('❌ Export ไม่ได้: ' + e.message); }
}

