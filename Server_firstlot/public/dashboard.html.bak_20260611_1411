function cutFilterLog() {
  const q   = (document.getElementById('cutSearchBox')?.value||'').toLowerCase();
  const shf = document.getElementById('cutFltShift')?.value;
  const mc  = document.getElementById('cutFltMachine')?.value;
  const from = document.getElementById('cutFltDateFrom')?.value || '';
  const to   = document.getElementById('cutFltDateTo')?.value   || '';
  const today = _localDateStr();
  cutFiltered = cutRecords.filter(r => {
    if (shf==='shift' && !cutInShift(r)) return false;
    if (shf==='today' && !(r.saved_at||'').startsWith(today)) return false;
    if (mc && r.mc_line !== mc) return false;
    const rd = (r.saved_at||'').slice(0,10);
    if (from && rd < from) return false;
    if (to   && rd > to)   return false;
    if (q) {
      const hay = [r.id_card,r.mc_line,r.tag_fg_no1,r.item_insulation,
                   r.vendor_insulation,r.item_type,r.leader_confirm,r.line].join(' ').toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });
  cutPage = 1;
  cutRenderTable();
}

function cutClearFilter() {
  const today = _localDateStr();
  document.getElementById('cutSearchBox').value = '';
  document.getElementById('cutFltShift').value = 'shift';
  document.getElementById('cutFltMachine').value = '';
  document.getElementById('cutFltDateFrom').value = today;
  document.getElementById('cutFltDateTo').value   = today;
