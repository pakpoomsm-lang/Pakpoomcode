        <div class="cmc-row">Vendor: <span style="color:#80cbc4">${esc(r.vendor_insulation||'—')}</span></div>
        <div class="cmc-row">Leader: <span>${esc(r.leader_confirm||'—')}</span></div>
        <div class="cmc-time">🕐 ${esc(dt)}</div>
      </div>
    </div>`;
  }).join('');
}

function cutPopulateMachineFilter() {
  const sel = document.getElementById('cutFltMachine');
  const cur = sel.value;
  const machines = [...new Set(cutRecords.map(r => r.mc_line).filter(Boolean))].sort();
  sel.innerHTML = '<option value="">Machine ทั้งหมด</option>'
    + machines.map(m => `<option value="${esc(m)}" ${m===cur?'selected':''}>${esc(m)}</option>`).join('');
