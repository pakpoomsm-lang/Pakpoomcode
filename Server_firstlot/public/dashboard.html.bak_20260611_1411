function closeAdminPin() {
  document.getElementById('adminPinOverlay').classList.remove('open');
}

function checkAdminPin() {
  const val = document.getElementById('adminPinInput').value;
  if (val === _ADMIN_PIN) {
    closeAdminPin();
    window.open('http://10.235.117.215:3001/expander/firstlot/admin', 'win_admin');
  } else {
    const errEl = document.getElementById('adminPinErr');
    errEl.textContent = '❌ รหัสไม่ถูกต้อง';
    document.getElementById('adminPinInput').value = '';
    document.getElementById('adminPinInput').focus();
    setTimeout(() => { errEl.textContent = ''; }, 2000);
  }
}

