<script>
// ─── Local date helper (ป้องกัน toISOString() ที่เป็น UTC ทำให้วันผิดช่วง 00:00-06:59 ICT) ──
function _localDateStr(d) {
  d = d || new Date();
  const y  = d.getFullYear();
  const mo = String(d.getMonth()+1).padStart(2,'0');
  const dy = String(d.getDate()).padStart(2,'0');
  return y+'-'+mo+'-'+dy;
}

// ─── State ────────────────────────────────────────────────────────────────────
let allRecords = [];
let filtered   = [];
let currentPage = 1;
let PAGE_SIZE   = 10;

// ─── Shift Logic ──────────────────────────────────────────────────────────────
// Day   shift: 07:40 – 19:35
// Night shift: 19:40 – 07:35 (ข้ามคืน)
function getCurrentShift() {
  const now  = new Date();
  const hhmm = now.getHours() * 60 + now.getMinutes();
  const day_start  = 7*60+40;   // 07:40
  const day_end    = 19*60+35;  // 19:35
  const night_start= 19*60+40;  // 19:40
  if (hhmm >= day_start && hhmm <= day_end)    return 'day';
  if (hhmm >= night_start || hhmm <= 7*60+35)  return 'night';
  return 'day';
}

function getShiftStart() {
  const now    = new Date();
  const hhmm   = now.getHours() * 60 + now.getMinutes();
  const shift  = getCurrentShift();
  const start  = new Date(now);
  if (shift === 'day') {
    start.setHours(7, 40, 0, 0);
  } else {
    // night shift: ถ้าเลย เที่ยงคืน ให้ย้อนกลับไปเมื่อวาน 19:40
    if (hhmm <= 7*60+35) {
      start.setDate(start.getDate() - 1);
    }
    start.setHours(19, 40, 0, 0);
  }
  return start;
}

let _lastKnownShift = null;   // ตรวจจับการเปลี่ยน Shift

function updateShiftBadge() {
  const shift    = getCurrentShift();

  // ── ตรวจจับการเปลี่ยน Shift → reset FP machine cards + reload ──
  if (_lastKnownShift !== null && _lastKnownShift !== shift) {
    // Shift เพิ่งเปลี่ยน — reset การ์ดเครื่องจักร FP ทันที
    const fpGrid = document.getElementById('fpMachineGrid');
    if (fpGrid) fpGrid.innerHTML = '<div class="no-machine">🔄 เปลี่ยน Shift — กำลังรีเซ็ต...</div>';
    // โหลดข้อมูลใหม่ (จะ filter เฉพาะ Shift ใหม่)
    if (typeof loadFP === 'function') loadFP();
  }
  _lastKnownShift = shift;

  const badge    = document.getElementById('shiftBadge');
  const label    = document.getElementById('shiftLabel');
  const sLabel   = document.getElementById('sShiftLbl');
  const shiftStart = getShiftStart();
  const timeStr  = shiftStart.toLocaleTimeString('th-TH', {hour:'2-digit', minute:'2-digit'});
  if (shift === 'day') {
    badge.textContent  = '🌤 Day Shift  07:40 – 19:35';
    badge.style.color  = '#ffd54f';
    badge.style.borderColor = '#ffd54f';
    badge.style.background  = '#271d00';
    label.textContent  = 'Day Shift (เริ่ม ' + timeStr + ')';
    sLabel.textContent = 'Day Shift นี้';
  } else {
    badge.textContent  = '🌙 Night Shift  19:40 – 07:35';
    badge.style.color  = '#90caf9';
    badge.style.borderColor = '#90caf9';
    badge.style.background  = '#0d1b2a';
    label.textContent  = 'Night Shift (เริ่ม ' + timeStr + ')';
    sLabel.textContent = 'Night Shift นี้';
  }
}

function isInCurrentShift(r) {
  if (!r.saved_at) return false;
  const savedAt = new Date(r.saved_at);
  return savedAt >= getShiftStart();
}

// ─── Date Filter Initialisation ───────────────────────────────────────────────
function initDateFilters() {
  const today = _localDateStr();   // 'yyyy-mm-dd'
  ['fltDateFrom','fltDateTo',
   'cutFltDateFrom','cutFltDateTo',
   'hpFltDateFrom','hpFltDateTo',
   'fpFltDateFrom','fpFltDateTo'].forEach(id => {
    const el = document.getElementById(id);
    if (el && !el.value) el.value = today;
  });
}

// ─── Load All ─────────────────────────────────────────────────────────────────
async function loadAll() {
  initDateFilters();
  try {
    const res = await fetch('/expander/firstlot/api/records/all');
    allRecords = await res.json();
    updateShiftBadge();
    updateSummary();
    updateMachineCards();
    populateMachineFilter();
    filterLog();
    document.getElementById('lastUpdate').textContent =
      'อัปเดต: ' + new Date().toLocaleTimeString('th-TH');
  } catch(e) {
    showToast('❌ โหลดข้อมูลไม่ได้: ' + e.message);
  }
}

// ─── Summary ──────────────────────────────────────────────────────────────────
function updateSummary() {
  const today = new Date().toLocaleDateString('en-GB'); // DD/MM/YYYY
  const pass  = allRecords.filter(r => (r.status||'').includes('PASS')).length;
  const fail  = allRecords.filter(r => (r.status||'').includes('FAIL')).length;
  const tod   = allRecords.filter(r => (r.date||'') === today).length;
  const shft  = allRecords.filter(isInCurrentShift).length;
  const mach  = new Set(allRecords.map(r=>r.machine).filter(Boolean)).size;
  document.getElementById('sTotal').textContent    = allRecords.length;
  document.getElementById('sPass').textContent     = pass;
  document.getElementById('sFail').textContent     = fail;
  document.getElementById('sToday').textContent    = tod;
  document.getElementById('sShift').textContent    = shft;
  document.getElementById('sMachines').textContent = mach;
}

// ─── Machine Cards ────────────────────────────────────────────────────────────
function updateMachineCards() {
  // เฉพาะ records ใน Shift ปัจจุบันเท่านั้น — reset เมื่อเปลี่ยน Shift
  const shiftRecords = allRecords.filter(isInCurrentShift);
  const byMachine = {};
  shiftRecords.forEach(r => {
    if (!r.machine) return;
    if (!byMachine[r.machine]) byMachine[r.machine] = { count: 0 };
    byMachine[r.machine].count++;
    if (!byMachine[r.machine].last || r.id > byMachine[r.machine].last.id) {
      byMachine[r.machine].last = r;
    }
  });

  const grid = document.getElementById('machineGrid');
  const machines = Object.keys(byMachine).sort();
  if (!machines.length) {
    grid.innerHTML = '<div class="no-machine">ยังไม่มีข้อมูล</div>'; return;
  }
  grid.innerHTML = machines.map(m => {
    const d = byMachine[m];
    const r = d.last;
    const st = (r.status||'');
    const isPass = st.includes('PASS');
    const isFail = st.includes('FAIL');
    const cls = isPass ? 'pass' : (isFail ? 'fail' : '');
    const stBadge = isPass
      ? '<span class="mc-status pass">✓ PASS</span>'
      : (isFail ? '<span class="mc-status fail">✗ FAIL</span>'
                : '<span class="mc-status na">— —</span>');
    return `
    <div class="m-card ${cls}">
      <div class="mc-count"><span class="n">${d.count}</span>Shift นี้</div>
      <div class="mc-machine">🔧 ${esc(m)}</div>
      ${stBadge}
      <div class="mc-fg">${esc(r.item_fg||'—')}</div>
      <div class="mc-row">Type: <span>${esc(r.item_type||'—')}</span></div>
      <div class="mc-row">Checker: <span>${esc(r.checker||'—')}</span></div>
      <div class="mc-row">Line: <span>${esc(r.line||'—')}</span> &nbsp;Seq: <span>${esc(r.seq||'—')}</span></div>
      <div class="mc-row">Remark: <span>${esc(r.remark||'—')}</span></div>
      <div class="mc-time">📅 ${esc(r.date||'—')} &nbsp;🕐 ${esc(r.time||'—')}</div>
    </div>`;
  }).join('');
}

// ─── Filter Options ───────────────────────────────────────────────────────────
function populateMachineFilter() {
  const sel = document.getElementById('fltMachine');
  const cur = sel.value;
  const machines = [...new Set(allRecords.map(r=>r.machine).filter(Boolean))].sort();
  sel.innerHTML = '<option value="">เครื่องทั้งหมด</option>'
    + machines.map(m=>`<option value="${esc(m)}" ${m===cur?'selected':''}>${esc(m)}</option>`).join('');
}

// ─── Log Filter ───────────────────────────────────────────────────────────────
function filterLog() {
  const q    = document.getElementById('searchBox').value.toLowerCase();
  const mch  = document.getElementById('fltMachine').value;
  const sts  = document.getElementById('fltStatus').value;
  const shft = document.getElementById('fltShift').value;
  const from = document.getElementById('fltDateFrom').value;   // yyyy-mm-dd
  const to   = document.getElementById('fltDateTo').value;
  const today = new Date().toLocaleDateString('en-GB');

  filtered = allRecords.filter(r => {
    if (mch && r.machine !== mch) return false;
    if (sts && !(r.status||'').includes(sts)) return false;
    if (shft === 'shift' && !isInCurrentShift(r)) return false;
    if (shft === 'today' && (r.date||'') !== today) return false;
    // Date range (uses saved_at ISO string, sliced to yyyy-mm-dd)
    const rd = (r.saved_at||'').slice(0,10);
    if (from && rd < from) return false;
    if (to   && rd > to)   return false;
    if (q) {
      const hay = [r.item_fg,r.machine,r.checker,r.confirm_checker,r.remark,r.item_type,r.status]
        .join(' ').toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });
  currentPage = 1;
  renderTable();
}

function clearFilter() {
  const today = _localDateStr();
  document.getElementById('searchBox').value = '';
  document.getElementById('fltMachine').value = '';
  document.getElementById('fltStatus').value = '';
  document.getElementById('fltShift').value = 'shift';
  document.getElementById('fltDateFrom').value = today;
  document.getElementById('fltDateTo').value   = today;
  filterLog();
}

function changePageSize() {
  PAGE_SIZE = parseInt(document.getElementById('pageSize').value);
  currentPage = 1;
  renderTable();
}

// ─── Render Table ─────────────────────────────────────────────────────────────
function renderTable() {
  const total = filtered.length;
  const pages = Math.max(1, Math.ceil(total / PAGE_SIZE));
  currentPage = Math.min(currentPage, pages);
  const start = (currentPage-1)*PAGE_SIZE;
  const slice = filtered.slice(start, start+PAGE_SIZE);

  document.getElementById('recordCount').textContent = `(${total} records)`;
  document.getElementById('pgInfo').textContent = `หน้า ${currentPage} / ${pages}`;
  document.getElementById('pgPrev').disabled = currentPage <= 1;
  document.getElementById('pgNext').disabled = currentPage >= pages;

  const tbody = document.getElementById('logBody');
  if (!slice.length) {
    tbody.innerHTML = '<tr><td colspan="23" style="text-align:center;color:var(--dim);padding:20px">ไม่พบข้อมูล</td></tr>';
    return;
  }
  tbody.innerHTML = slice.map((r,i) => {
    const no = start + i + 1;
    const st = (r.status||'');
    const badge = st.includes('PASS')
      ? `<span class="badge-pass">PASS</span>`
      : (st.includes('FAIL') ? `<span class="badge-fail">FAIL</span>` : `<span class="badge-na">—</span>`);
    return `<tr>
      <td class="td-id">${r.id}</td>
      <td>${esc(r.date||'')}</td>
      <td>${esc(r.time||'')}</td>
      <td class="td-machine">${esc(r.machine||'')}</td>
      <td class="td-fg">${esc(r.item_fg||'')}</td>
      <td>${esc(r.item_type||'')}</td>
      <td>${esc(r.checker||'')}</td>
      <td>${esc(r.confirm_checker||'')}</td>
      <td>${esc(r.line||'')}</td>
      <td>${esc(r.seq||'')}</td>
      <td>${esc(r.qty||'')}</td>
      <td style="font-weight:700">${avgFromStr(r.val_el)}</td>
      <td style="font-weight:700">${avgFromStr(r.val_a)}</td>
      <td style="font-weight:700">${avgFromStr(r.val_b)}</td>
      <td>${esc(r.flat_pct||'')}</td>
      <td>${esc(r.ap_hairpin||'')}</td>
      <td>${esc(r.ap_fin||'')}</td>
      <td>${esc(r.sp1||'')}</td>
      <td>${esc(r.sp2||'')}</td>
      <td>${esc(r.sp3||'')}</td>
      <td>${esc(r.mark_color||'')}</td>
      <td title="${esc(r.remark||'')}">${esc(r.remark||'')}</td>
      <td>${badge}</td>
    </tr>`;
  }).join('');
}

function changePage(d) {
  currentPage += d;
  renderTable();
}

// ─── Export CSV ───────────────────────────────────────────────────────────────
function exportCSV() {
  if (!filtered.length) { showToast('ไม่มีข้อมูลให้ Export'); return; }
  const headers = ['No','ID','Date','Time','Machine','Item FG','Type','Checker','Confirm Checker',
    'Line','Seq','Qty',
    'EL (raw)','EL Avg','A (raw)','A Avg','B (raw)','B Avg',
    'C','D','D%','Hairpin','FIN',
    'SP1','SP2','SP3','Pitch','Hairpin Item','FIN Item',
    'Mark Color','Mark Status','Remark','Status','Saved At'];
  const rows = filtered.map((r,i) => [
    i+1, r.id, r.date, r.time, r.machine, r.item_fg, r.item_type,
    r.checker, r.confirm_checker, r.line, r.seq, r.qty,
    r.val_el, avgFromStr(r.val_el),
    r.val_a,  avgFromStr(r.val_a),
    r.val_b,  avgFromStr(r.val_b),
    r.val_c, r.val_d, r.flat_pct,
    r.ap_hairpin, r.ap_fin,
    r.sp1, r.sp2, r.sp3, r.pitch, r.hairpin_item, r.fin_item,
    r.mark_color, r.mark_status, r.remark, r.status, r.saved_at
  ].map(v => '"'+(String(v??'').replace(/"/g,'""'))+'"'));

  const csv = '﻿' + [headers, ...rows].map(r=>r.join(',')).join('\r\n');
  const blob = new Blob([csv], {type:'text/csv;charset=utf-8'});
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url;
  a.download = 'expander_log_' + _localDateStr() + '.csv';
  a.click();
  URL.revokeObjectURL(url);
  showToast(`✓ Export CSV สำเร็จ (${filtered.length} records)`);
}

// ─── Export Excel ─────────────────────────────────────────────────────────────
async function exportExcel() {
  showToast('⏳ กำลัง Export Excel...');
  try {
    const r = await fetch('/expander/firstlot/api/export');
    const d = await r.json();
    if (d.ok) showToast(`✓ Export Excel สำเร็จ (${d.rows} records) — ไฟล์: ${d.file}`);
    else showToast('❌ Error: ' + d.error);
  } catch(e) { showToast('❌ ' + e.message); }
}

// ─── Helpers ──────────────────────────────────────────────────────────────────
function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function avgFromStr(str) {
  if (!str) return '—';
  const nums = String(str).split(',').map(v => parseFloat(v.trim())).filter(v => !isNaN(v));
  if (!nums.length) return '—';
  return (nums.reduce((s, v) => s + v, 0) / nums.length).toFixed(2);
}
function showToast(msg, dur=3500) {
