// ─── Show coil detail for a single HP record row ──────────────────────────────
let _coilRecordIdx = -1;  // currently displayed globalIdx in popup

function hpShowRecordCoils(globalIdx) {
  const r = hpFiltered[globalIdx];
  if (!r) return;
  _coilRecordIdx = globalIdx;

  let cd = [];
  try { cd = JSON.parse(r.coil_data || '[]'); } catch(e) {}
  let mf = [];
  try { mf = JSON.parse(r.meas_full || '[]'); } catch(e) {}

  const ts = r.ts || r.saved_at || '';
  const date = ts.slice(0, 10);

  // Build entries for this single record — join coil_data[i] with meas_full[i]
  _coilEntries = [];
  cd.forEach((c, i) => {
    if (!c) return;
    const m = mf[i] || {};
    const l1 = (m.l1 !== undefined && m.l1 !== null && m.l1 !== '') ? parseFloat(m.l1) : null;
    const l2 = (m.l2 !== undefined && m.l2 !== null && m.l2 !== '') ? parseFloat(m.l2) : null;
    const diff = (l1 !== null && l2 !== null) ? parseFloat((l1 - l2).toFixed(2)) : null;
    _coilEntries.push({
      slot: i + 1,
      raw: c.raw || '',
      vendor: c.vendor || '—',
      coilNo: c.coilNo || '',
      blackPoint: c.blackPoint != null ? c.blackPoint : 0,
      l1, l2, diff,
      a:  (m.a  !== undefined && m.a  !== null && m.a  !== '') ? parseFloat(m.a)  : null,
      b:  (m.b  !== undefined && m.b  !== null && m.b  !== '') ? parseFloat(m.b)  : null,
      flat: (m.flat !== undefined && m.flat !== null && m.flat !== '') ? parseFloat(m.flat) : null,
      result: c.result || 'OK',
      mc: r.mc || '',
      date: date
    });
  });

  _coilSort  = 'slot';
  _coilQuery = '';
  document.getElementById('coilPanelSearch').value = '';
  document.getElementById('coilPanelTitle').textContent =
    `🔩 Coil — ${esc(r.mc||'—')}  Seq.${esc(r.seq||'—')}  (${_coilEntries.length} coil)`;

  document.getElementById('coilPanelCount').textContent = `(${_coilEntries.length} coil entries)`;

  // Nav info & button states
  const total = hpFiltered.length;
  document.getElementById('coilNavInfo').textContent = `${globalIdx + 1} / ${total}`;
  document.getElementById('coilNavPrev').disabled = globalIdx <= 0;
  document.getElementById('coilNavNext').disabled = globalIdx >= total - 1;
  document.getElementById('coilNavPrev').style.opacity = globalIdx <= 0 ? '0.35' : '1';
  document.getElementById('coilNavNext').style.opacity = globalIdx >= total - 1 ? '0.35' : '1';

  // Reset sort buttons to none active for single-record view
  ['cpSortCoil','cpSortVendor','cpSortDate'].forEach(id =>
    document.getElementById(id).classList.remove('active'));

  let rows = '';
  _coilEntries.forEach((e) => {
    const bpColor = e.blackPoint >= 8 ? 'color:#ef9a9a' : (e.blackPoint >= 5 ? 'color:#ffe082' : 'color:#a5d6a7');
    const resBadge = e.result === 'NG'
      ? `<span class="cp-ng">NG</span>` : `<span class="cp-ok">OK</span>`;
    const fmtNum  = v => v !== null ? v.toFixed(2) : '<span style="color:var(--dim)">—</span>';
    const diffOK  = e.diff !== null && e.diff >= -1 && e.diff <= 1;
    const diffColor = e.diff === null ? 'color:var(--dim)' : (diffOK ? 'color:#69ff47;font-weight:700' : 'color:#ff5252;font-weight:700');
    const flatOK  = e.flat !== null && e.flat >= 0 && e.flat <= 20;
    const flatColor = e.flat === null ? 'color:var(--dim)' : (flatOK ? 'color:#69ff47;font-weight:700' : 'color:#ff5252;font-weight:700');
    const fmtFlat = e.flat !== null ? e.flat.toFixed(1) + '%' : '<span style="color:var(--dim)">—</span>';
    rows += `<tr>
      <td class="cp-no">${e.slot}</td>
      <td class="cp-raw">${esc(e.raw.substring(0, 22))}</td>
      <td class="cp-vendor">${esc(e.vendor)}</td>
      <td class="cp-coilno">${esc(e.coilNo)}</td>
      <td class="cp-bp" style="${bpColor};text-align:center">${e.blackPoint}</td>
      <td style="text-align:center;font-family:var(--mono)">${fmtNum(e.l1)}</td>
      <td style="text-align:center;font-family:var(--mono)">${fmtNum(e.l2)}</td>
      <td style="text-align:center;font-family:var(--mono);${diffColor}">${fmtNum(e.diff)}</td>
      <td style="text-align:center;font-family:var(--mono)">${fmtNum(e.a)}</td>
      <td style="text-align:center;font-family:var(--mono)">${fmtNum(e.b)}</td>
      <td style="text-align:center;font-family:var(--mono);${flatColor}">${fmtFlat}</td>
      <td>${resBadge}</td>
      <td class="cp-mc">${esc(e.mc)}</td>
      <td style="color:var(--dim);font-size:11px">${esc(e.date)}</td>
    </tr>`;
  });
  if (!rows) rows = `<tr><td colspan="14" style="text-align:center;color:var(--dim);padding:24px">ไม่พบข้อมูล Coil</td></tr>`;
  document.getElementById('coilPanelBody').innerHTML = rows;

  document.getElementById('coilPanelOverlay').style.display = 'flex';
}

