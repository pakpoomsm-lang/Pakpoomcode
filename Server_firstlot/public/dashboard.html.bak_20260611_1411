  document.getElementById('fpRecordCount').textContent = `(${total} records)`;
  document.getElementById('fpPgInfo').textContent = `หน้า ${fpCurrentPage} / ${pages}`;
  document.getElementById('fpPgPrev').disabled = fpCurrentPage <= 1;
  document.getElementById('fpPgNext').disabled = fpCurrentPage >= pages;

  const tbody = document.getElementById('fpLogBody');
