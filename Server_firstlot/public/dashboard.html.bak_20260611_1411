// ── Instant refresh เมื่อ process ใดก็ตามบันทึกข้อมูล ────────────────────────
(function() {
  function _onProcessSaved() { loadAll(); }
  // BroadcastChannel (same-origin multi-window)
  try {
    const bc = new BroadcastChannel('dash_refresh');
    bc.onmessage = _onProcessSaved;
  } catch(e) {}
  // localStorage fallback (cross-window storage event)
  window.addEventListener('storage', function(e) {
    if (e.key === 'dash_refresh') _onProcessSaved();
  });
})();

