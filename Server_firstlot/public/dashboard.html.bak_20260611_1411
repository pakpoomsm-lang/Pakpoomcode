function hpExportCSV() {
  if (!hpFiltered.length) { showToast('ไม่มีข้อมูลให้ Export'); return; }
  const cv = v => '"' + String(v == null ? '' : v).replace(/"/g,'""') + '"';
  const NUM = 14;
  const mcName = mc => mc && mc.toUpperCase().startsWith('HB')
    ? 'Hairpin Bender No.' + mc.slice(2) : (mc||'');

  // Header row 1 (85 cols: 12 base + 28 coil/bp + 42 meas + 3 appearance)
  const h1 = ['Date','Time','Line','Seq','Prod/month',
               'Machine Hairpin Bender',
               'Item Hairpin','Item FG','Type','Item Copper',
               'Coil Size','Vender'];
  for (let n = 1; n <= NUM; n++) h1.push(`Coil No. ${n}`, 'Black point');
  for (let n = 1; n <= NUM; n++) h1.push(`Line ${n}`, '', 'Flatness');
  h1.push('Apprence check', '', 'ผู้ลงบันทึก');

  // Header row 2
  const h2 = Array(12 + NUM * 2).fill('');
  for (let i = 0; i < NUM; i++) h2.push('L1 ±1 mm. / L2 ±1 mm.', 'D (0-1mm)', '≤20% OK.');
  h2.push('ไม่มีรอยขีดบริเวณโค้งท่อ', 'รอยย่นไม่เกิน limit กำหนด', '');

  // Data rows — one row per inspection record
  const dataRows = [];
  hpFiltered.forEach(r => {
    let mf = [], cd = [], vis = [];
    try { mf  = JSON.parse(r.meas_full  || '[]'); } catch(e) {}
    try { cd  = JSON.parse(r.coil_data  || '[]'); } catch(e) {}
    try { vis = JSON.parse(r.visuals    || '[]'); } catch(e) {}
    const ts = r.ts || r.saved_at || '';
    const date = ts.slice(0, 10), time = ts.slice(11, 19);
    const machine = mcName(r.mc);

    const row = [date, time, r.line||'', r.seq||'', r.prod_month||'',
                 machine,
                 r.item||'', r.item_fg||'', r.item_type||'', r.cu_item||'',
                 r.coil_size||'', r.vendor||''];

    // 14 coil pairs (Coil No. + Black point)
    for (let i = 0; i < NUM; i++) {
      const c = cd[i] || null;
      row.push(c ? (c.coilNo || '') : '');
      row.push(c ? (c.blackPoint != null ? c.blackPoint : '') : '');
    }

    // 14 line measurement groups (L1/L2, D, Flatness%)
    for (let i = 0; i < NUM; i++) {
      const m = mf[i] || null;
      const l1l2 = m ? `${m.l1 != null ? m.l1 : ''} / ${m.l2 != null ? m.l2 : ''}` : '';
      const diff = m ? (m.diff != null ? m.diff : (m.a != null ? m.a : '')) : '';
      const flat = m && m.flat != null ? m.flat : '';
      row.push(l1l2, diff, flat);
    }

    // 3 appearance columns
    row.push(vis[0] || '', vis[1] || '', r.checker || '');

    dataRows.push(row.map(cv).join(','));
  });

  const csv = '﻿' + [h1.map(cv).join(','), h2.map(cv).join(','), ...dataRows].join('\r\n');
  const blob = new Blob([csv], {type:'text/csv;charset=utf-8'});
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url;
  a.download = 'hp_log_' + _localDateStr() + '.csv';
  a.click();
  URL.revokeObjectURL(url);
  showToast(`✓ Export CSV สำเร็จ (${hpFiltered.length} records)`);
}

